<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SAMS.Mobile.Views.LoginPage"
             Title="Student Login">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
            <Label Text="SAMS Mobile" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="Sign in with your student account" HorizontalOptions="Center" TextColor="Gray" />

            <Frame BackgroundColor="{StaticResource Card}" BorderColor="#E2E7F2" CornerRadius="12">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Email" Keyboard="Email" Text="{Binding Email}" />
                    <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}" />
                    <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding HasError}" />
                    <Button Text="Login" BackgroundColor="{StaticResource Primary}" TextColor="White" Command="{Binding LoginCommand}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
