<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SAMS.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SAMS.Mobile.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar Route="main">
        <ShellContent
            Title="Login"
            Route="login"
            ContentTemplate="{DataTemplate views:LoginPage}" />
        <ShellContent
            Title="Home"
            Route="home"
            ContentTemplate="{DataTemplate views:StudentHomePage}" />
        <ShellContent
            Title="Attendance"
            Route="attendance-history"
            ContentTemplate="{DataTemplate views:AttendanceHistoryPage}" />
    </TabBar>
</Shell>
